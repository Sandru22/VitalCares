<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    xmlns:views="clr-namespace:VitalCares.Views"
    x:Class="VitalCares.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="VitalCares">

    <TabBar>
        <Tab Title="Live" Icon="dashboard_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" />
        </Tab>
        <Tab Title="Istoric" Icon="history_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:ConnectionTest}" />
        </Tab>
        <Tab Title="Recomandari" Icon="history_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:RecommendationsPage}" />
        </Tab>
        <Tab Title="Calendar" Icon="history_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:Calendar}" />
        </Tab>
    </TabBar>
</Shell>