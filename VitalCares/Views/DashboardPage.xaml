<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCares.Views.DashboardPage"
             Title="DashboardPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="DATE COLECTATE LIVE (10s)" 
                   FontSize="12" 
                   FontAttributes="Bold" 
                   TextColor="#5F6368"
                   HorizontalOptions="Center" />

            <Border Stroke="#E0E0E0"
                    StrokeThickness="1"
                    Background="White"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.05" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="RITM CARDIAC" 
                           FontSize="14" 
                           TextColor="#70757A" 
                           HorizontalOptions="Center" />
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="{Binding CurrentPuls}" 
                               FontSize="54" 
                               FontAttributes="Bold" 
                               TextColor="#D32F2F" />
                        <Label Text="BPM" 
                               FontSize="18" 
                               VerticalOptions="End" 
                               Margin="0,0,0,12" 
                               TextColor="#D32F2F" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                <Border Grid.Column="0" Stroke="#E0E0E0" StrokeThickness="1" Background="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="TEMP." FontSize="12" TextColor="#70757A" HorizontalOptions="Center" />
                        <Label Text="{Binding CurrentTemp, StringFormat='{0:F1}°C'}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="#1976D2" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Stroke="#E0E0E0" StrokeThickness="1" Background="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="UMIDITATE" FontSize="12" TextColor="#70757A" HorizontalOptions="Center" />
                        <Label Text="{Binding CurrentHumidity, StringFormat='{0}%'}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="#00796B" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label Text="RECOMANDĂRI MEDICALE" FontSize="14" FontAttributes="Bold" Margin="5,10,0,0" TextColor="#5F6368"/>
            <Border Stroke="#2196F3" StrokeThickness="2" Background="#E3F2FD" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding MedicRecommendation}" 
                           FontSize="16" 
                           TextColor="#0D47A1" 
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Button Text="SEMALEAZĂ STARE NOUĂ" 
                    Command="{Binding AddNoteCommand}"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="55"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,15,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>