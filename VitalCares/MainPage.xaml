<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalCares.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Stare Pacient" FontSize="24" FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="20">
                <Label Text="{Binding CurrentPuls, StringFormat='Puls: {0} bpm'}" />
                <Label Text="{Binding CurrentTemp, StringFormat='Temp: {0} °C'}" />
            </HorizontalStackLayout>

                <VerticalStackLayout>
                    <Label Text="Recomandările Medicului" FontAttributes="Bold" />
                    <Label Text="{Binding MedicRecommendation}" TextColor="DarkGreen" />
                </VerticalStackLayout>

            <Button Text="Adaugă Notă Alarmă" Clicked="OnAddAlarmNoteClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
